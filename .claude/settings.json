{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Read(*)",
      "Edit(*)",
      "WebSearch",
      "WebFetch(*)",
      "Bash(*)"
    ],
    "deny": [
      "Bash(git push*)",
      "Bash(git push --force*)",
      "Bash(git -C * push*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(sudo *)",
      "Bash(curl *| bash*)",
      "Bash(curl *| sh*)",
      "Bash(wget *| bash*)",
      "Bash(wget *| sh*)",
      "Bash(cat ~/.ssh/*)",
      "Bash(cat .env*)",
      "Edit(.env*)",
      "Edit(**/.env*)",
      "Bash(sed -i*)",
      "Bash(gsed -i*)",
      "Bash(perl -i*)",
      "Bash(perl -pi*)",
      "Bash(perl -ni*)",
      "Bash(perl -pie*)",
      "Bash(perl -nie*)",
      "Bash(awk -i inplace*)",
      "Bash(gawk -i inplace*)",
      "Bash(find * -delete*)",
      "Bash(find * -exec rm *)",
      "Bash(find * -exec mv *)",
      "Bash(find * -exec sed *)",
      "Bash(find * -exec gsed *)",
      "Bash(find * -exec perl *)",
      "Bash(find * -exec awk *)",
      "Bash(find * -execdir rm *)",
      "Bash(find * -execdir mv *)",
      "Bash(find * -execdir sed *)",
      "Bash(find * -execdir perl *)",
      "Bash(xargs rm*)",
      "Bash(xargs mv*)",
      "Bash(xargs sed*)",
      "Bash(xargs gsed*)",
      "Bash(xargs perl*)",
      "Bash(xargs awk*)",
      "Bash(xargs -* rm*)",
      "Bash(xargs -* mv*)",
      "Bash(xargs -* sed*)",
      "Bash(xargs -* perl*)",
      "Bash(xargs -* awk*)",
      "Bash(* | xargs rm*)",
      "Bash(* | xargs mv*)",
      "Bash(* | xargs sed*)",
      "Bash(* | xargs perl*)",
      "Bash(* | xargs awk*)",
      "Bash(* | xargs -* rm*)",
      "Bash(* | xargs -* mv*)",
      "Bash(* | xargs -* sed*)",
      "Bash(* | xargs -* perl*)",
      "Bash(* | xargs -* awk*)",
      "Bash(* |xargs rm*)",
      "Bash(* |xargs mv*)",
      "Bash(* |xargs sed*)",
      "Bash(* |xargs perl*)",
      "Bash(* |xargs awk*)",
      "Bash(jscodeshift*)",
      "Bash(npx jscodeshift*)",
      "Bash(npx -y jscodeshift*)",
      "Bash(codemod*)",
      "Bash(npx codemod*)",
      "Bash(npx -y codemod*)",
      "Bash(ast-grep * --rewrite*)",
      "Bash(ast-grep * --update-all*)",
      "Bash(sg * --rewrite*)",
      "Bash(sg * --update-all*)"
    ]
  }
}
