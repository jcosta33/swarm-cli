{
    "compilerOptions": {
    "strictNullChecks": true,
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "esModuleInterop": true,
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "types": ["node"],
        "strict": true,
        "noImplicitAny": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["src/**/*", "bin/**/*"]
}
