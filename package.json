{
  "name": "swarm-cli",
  "version": "1.0.0",
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,js,mjs,cjs,json,md}\"",
    "lint": "eslint --cache --cache-location node_modules/.cache/eslint/ \"src/**/*.ts\"",
    "lint:fix": "eslint --cache --cache-location node_modules/.cache/eslint/ --fix \"src/**/*.ts\"",
    "deps:validate": "depcruise src --config .dependency-cruiser.cjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/proper-lockfile": "^4.1.4",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "knip": "^6.5.0",
    "prettier": "^3.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "bin": {
    "swarm": "./bin/swarm.js"
  },
  "type": "module",
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "better-sqlite3": "^12.9.0",
    "picocolors": "^1.1.1",
    "proper-lockfile": "^4.1.2"
  }
}