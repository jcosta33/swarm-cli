{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": true
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.spec.ts",
        "src/**/*.spec.tsx",
        "src/**/*.test.ts",
        "src/**/*.test.tsx",
        "bin/**/*.js",
        "eslint.config.mjs",
        "eslint.fast.config.mjs"
    ],
    "exclude": [
        "dist",
        "build",
        "coverage",
        "node_modules"
    ]
}
